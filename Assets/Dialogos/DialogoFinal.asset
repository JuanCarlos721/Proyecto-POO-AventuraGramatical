  lineas:
  - nombrePersonaje: Erizo
    spritePersonaje: {fileID: 7474645754422865998, guid: 86dbe51360f9ded4f936f45a1bb11377, type: 3}
    audioLinea: {fileID: 8300000, guid: c8b4724abe4d0414b972d12732a753cb, type: 3}
    texto: "Incre\xEDble\u2026 lograste poner todo en orden. Las oraciones han recuperado
      su estructura y ahora todo vuelve a tener sentido. No cualquiera puede dominar
      las funciones gramaticales as\xED. Gracias a ti, la oficina ya no es un desastre.
      \xA1Sigue asi!"
